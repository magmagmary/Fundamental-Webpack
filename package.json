    "ts-loader": "9.5.1",
    "typescript": "5.5.3",
    "webpack": "5.91.0",
    "webpack-bundle-analyzer": "4.10.1",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.0.4",
    "webpack-manifest-plugin": "5.0.0",
    "webpack-merge": "6.0.1"
