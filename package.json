{
  "name": "webpack-fundamentals",
  "license": "MIT",
  "author": "MagMagMary 70",
  "scripts": {
    "start": "cross-env webpack serve --config webpack/webpack.dev.config.js",
    "build": "cross-env webpack --config webpack/webpack.prod.config.js --progress",
    "lint": "run-p 'lint:*' --continue-on-error",
    "lint:format": "prettier --check .",
    "lint:js": "eslint . --cache --ext .js,.ts,.tsx",
    "lint-fix": "run-s 'lint-fix:*' --continue-on-error",
    "lint-fix:format": "prettier --write .",
    "lint-fix:js": "run-s 'lint:js --fix'",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@babel/core": "7.24.4",
